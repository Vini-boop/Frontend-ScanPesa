# =============================================
# ScanPesa Web — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git
# =============================================

# Your deployed backend URL (no trailing slash)
# Vercel will proxy /api → this URL via vercel.json
VITE_API_URL=https://your-backend.onrender.com

# Your deployed frontend URL (used in QR codes so phones can scan them)
VITE_WEB_URL=https://your-frontend.vercel.app

# --- Firebase (optional — polling works without it) ---
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
